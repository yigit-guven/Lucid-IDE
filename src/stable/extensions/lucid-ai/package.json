{
  "name": "lucid-ai",
  "displayName": "AI Chat",
  "description": "Integrated local AI model manager and chat assistant for Lucid IDE",
  "version": "1.0.0",
  "publisher": "vscode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:lucid.chatView"
  ],
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "lucid-ai-sidebar",
          "title": "AI Chat",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "lucid-ai-sidebar": [
        {
          "type": "webview",
          "id": "lucid.chatView",
          "name": "AI Chat",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "lucid.chat.clear",
        "title": "Clear Chat History",
        "icon": "$(trash)"
      },
      {
        "command": "lucid.chat.focus",
        "title": "Focus Chat Input"
      },
      {
        "command": "lucid.scm.generateCommit",
        "title": "Generate Commit Message (AI)",
        "icon": "$(sparkle)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "lucid.chat.clear",
          "when": "view == lucid.chatView",
          "group": "navigation"
        }
      ],
      "scm/title": [
        {
          "command": "lucid.scm.generateCommit",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  }
}
