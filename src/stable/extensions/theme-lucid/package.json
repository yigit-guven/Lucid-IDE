{
  "name": "theme-lucid",
  "displayName": "Lucid IDE Themes",
  "description": "Custom color themes for Lucid IDE",
  "version": "1.0.0",
  "publisher": "yigit-guven",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Lucid Light",
        "uiTheme": "vs",
