      },
      {
        "label": "Lucid Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/lucid-dark.json"
      }
    ],
    "configurationDefaults": {
      "workbench.colorTheme": "Lucid Dark"
    }
  },
  "author": "Yiğit Güven"
}