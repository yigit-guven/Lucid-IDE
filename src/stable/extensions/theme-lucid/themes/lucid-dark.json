{
  "name": "Lucid Dark",
  "colors": {
    "editor.background": "#0b0f19",
    "editor.foreground": "#e6edf3",
    "editor.lineHighlightBackground": "#161b26",
    "editor.selectionBackground": "#1f293d",
    "editor.inactiveSelectionBackground": "rgba(31, 41, 61, 0.5)",
    "editorCursor.foreground": "#38bdf8",
    "editorWhitespace.foreground": "#334155",
    "sideBar.background": "#111622",
    "sideBar.foreground": "#8b949e",
    "sideBar.border": "#1f293d",
    "sideBarTitle.foreground": "#e6edf3",
    "sideBarSectionHeader.background": "#111622",
    "sideBarSectionHeader.foreground": "#c9d1d9",
    "sideBarSectionHeader.border": "#1f293d",
    "activityBar.background": "#0b0f19",
    "activityBar.foreground": "#e6edf3",
    "activityBar.inactiveForeground": "#8b949e",
    "activityBar.border": "#1f293d",
    "activityBar.activeBorder": "#38bdf8",
    "activityBarBadge.background": "#1d4ed8",
    "activityBarBadge.foreground": "#ffffff",
    "statusBar.background": "#0b0f19",
    "statusBar.foreground": "#8b949e",
    "statusBar.border": "#1f293d",
    "editorGroupHeader.tabsBackground": "#111622",
    "editorGroupHeader.tabsBorder": "#1f293d",
    "tab.activeBackground": "#0b0f19",
    "tab.activeForeground": "#e6edf3",
    "tab.activeBorder": "#0b0f19",
    "tab.activeBorderTop": "#38bdf8",
    "tab.inactiveBackground": "#111622",
    "tab.inactiveForeground": "#8b949e",
    "tab.border": "#1f293d",
    "titleBar.activeBackground": "#0b0f19",
    "titleBar.activeForeground": "#e6edf3",
    "titleBar.border": "#1f293d",
    "input.background": "#161b26",
    "input.border": "#1f293d",
    "input.foreground": "#e6edf3",
    "input.placeholderForeground": "#484f58",
    "button.background": "#1d4ed8",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#2563eb",
    "focusBorder": "#38bdf8",
    "list.activeSelectionBackground": "#1f293d",
    "list.activeSelectionForeground": "#e6edf3",
    "list.hoverBackground": "rgba(255, 255, 255, 0.03)",
    "list.inactiveSelectionBackground": "rgba(31, 41, 61, 0.5)",
    "panel.background": "#0b0f19",
    "panel.border": "#1f293d",
    "panelTitle.activeBorder": "#38bdf8",
    "panelTitle.activeForeground": "#e6edf3",
    "panelTitle.inactiveForeground": "#8b949e",
    "terminal.background": "#0b0f19",
    "terminal.foreground": "#e6edf3"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8b949e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff7b72",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#d2a8ff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e6edf3"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#c9d1d9"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#ff7b72"
      }
    }
  ]
}