{
  "name": "Lucid Dark",
  "colors": {
    "editor.background": "#030712",
    "editor.foreground": "#f3f4f6",
    "editor.lineHighlightBackground": "#0b1329",
    "editor.selectionBackground": "#172554",
    "editor.inactiveSelectionBackground": "#17255480",
    "editorCursor.foreground": "#38bdf8",
    "editorWhitespace.foreground": "#334155",
    "sideBar.background": "#080c18",
    "sideBar.foreground": "#8b949e",
    "sideBar.border": "#111827",
    "sideBarTitle.foreground": "#e6edf3",
    "sideBarSectionHeader.background": "#080c18",
    "sideBarSectionHeader.foreground": "#c9d1d9",
    "sideBarSectionHeader.border": "#111827",
    "activityBar.background": "#030712",
    "activityBar.foreground": "#e6edf3",
    "activityBar.inactiveForeground": "#8b949e",
    "activityBar.border": "#111827",
    "activityBar.activeBorder": "#38bdf8",
    "activityBarBadge.background": "#1d4ed8",
    "activityBarBadge.foreground": "#ffffff",
    "statusBar.background": "#030712",
    "statusBar.foreground": "#8b949e",
    "statusBar.border": "#111827",
    "statusBar.noFolderBackground": "#030712",
    "statusBar.debuggingBackground": "#030712",
    "editorGroupHeader.tabsBackground": "#080c18",
    "editorGroupHeader.tabsBorder": "#111827",
    "tab.activeBackground": "#030712",
    "tab.activeForeground": "#e6edf3",
    "tab.activeBorder": "#030712",
    "tab.activeBorderTop": "#38bdf8",
    "tab.inactiveBackground": "#080c18",
    "tab.inactiveForeground": "#8b949e",
    "tab.border": "#111827",
    "titleBar.activeBackground": "#030712",
    "titleBar.activeForeground": "#e6edf3",
    "titleBar.border": "#111827",
    "input.background": "#080c18",
    "input.border": "#111827",
    "input.foreground": "#e6edf3",
    "input.placeholderForeground": "#484f58",
    "button.background": "#1d4ed8",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#2563eb",
    "focusBorder": "#38bdf8",
    "list.activeSelectionBackground": "#1e293b",
    "list.activeSelectionForeground": "#e6edf3",
    "list.hoverBackground": "#ffffff0d",
    "list.hoverForeground": "#f3f4f6",
    "list.focusBackground": "#1e293b",
    "list.focusForeground": "#f3f4f6",
    "list.inactiveSelectionBackground": "#1e293b80",
    "list.inactiveSelectionForeground": "#f3f4f6",
    "list.inactiveSelectionIconForeground": "#f3f4f6",
    "list.activeSelectionIconForeground": "#f3f4f6",
    "tab.hoverBackground": "#ffffff08",
    "tab.hoverBorder": "#111827",
    "tab.hoverForeground": "#f3f4f6",
    "tab.unfocusedHoverBackground": "#ffffff05",
    "tab.unfocusedHoverBorder": "#111827",
    "tab.unfocusedHoverForeground": "#8b949e",
    "editor.hoverHighlightBackground": "#38bdf81a",
    "editorHoverWidget.background": "#080c18",
    "editorHoverWidget.border": "#111827",
    "editorHoverWidget.foreground": "#f3f4f6",
    "editorHoverWidget.statusBarBackground": "#030712",
    "statusBarItem.hoverBackground": "#ffffff0d",
    "statusBarItem.activeBackground": "#ffffff1a",
    "activityBar.activeBackground": "#ffffff08",
    "menubar.selectionBackground": "#1e293b",
    "menubar.selectionForeground": "#f3f4f6",
    "menu.selectionBackground": "#1e293b",
    "menu.selectionForeground": "#f3f4f6",
    "toolbar.hoverBackground": "#ffffff0d",
    "toolbar.hoverOutline": "#00000000",
    "toolbar.activeBackground": "#ffffff1a",
    "panel.background": "#030712",
    "panel.border": "#111827",
    "panelTitle.activeBorder": "#38bdf8",
    "panelTitle.activeForeground": "#e6edf3",
    "panelTitle.inactiveForeground": "#8b949e",
    "terminal.background": "#030712",
    "terminal.foreground": "#e6edf3"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8b949e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff9e64",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#d2a8ff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e6edf3"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#c9d1d9"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    }
  ]
}