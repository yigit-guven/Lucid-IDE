{
  "name": "Lucid Light",
  "colors": {
    "editor.background": "#f0f7fb",
    "editor.foreground": "#1e293b",
    "editor.lineHighlightBackground": "#e4f0f8",
    "editor.selectionBackground": "#cbe0f0",
    "editor.inactiveSelectionBackground": "#dbe9f4",
    "editorCursor.foreground": "#0284c7",
    "editorWhitespace.foreground": "#cbd5e1",
    "sideBar.background": "#e1edf5",
    "sideBar.foreground": "#475569",
    "sideBar.border": "#b9cbd9",
    "sideBarTitle.foreground": "#0f172a",
    "sideBarSectionHeader.background": "#d5e4ee",
    "sideBarSectionHeader.foreground": "#334155",
    "sideBarSectionHeader.border": "#b9cbd9",
    "activityBar.background": "#d2e2ee",
    "activityBar.foreground": "#0f172a",
    "activityBar.inactiveForeground": "#64748b",
    "activityBar.border": "#b9cbd9",
    "activityBar.activeBorder": "#0284c7",
    "activityBarBadge.background": "#0284c7",
    "activityBarBadge.foreground": "#ffffff",
    "statusBar.background": "#cbdbe7",
    "statusBar.foreground": "#334155",
    "statusBar.border": "#b9cbd9",
    "statusBar.noFolderBackground": "#cbdbe7",
    "statusBar.debuggingBackground": "#cbdbe7",
    "editorGroupHeader.tabsBackground": "#e1edf5",
    "editorGroupHeader.tabsBorder": "#b9cbd9",
    "tab.activeBackground": "#f0f7fb",
    "tab.activeForeground": "#0f172a",
    "tab.activeBorder": "#f0f7fb",
    "tab.activeBorderTop": "#0284c7",
    "tab.inactiveBackground": "#e1edf5",
    "tab.inactiveForeground": "#64748b",
    "tab.border": "#b9cbd9",
    "titleBar.activeBackground": "#d2e2ee",
    "titleBar.activeForeground": "#0f172a",
    "titleBar.border": "#b9cbd9",
    "input.background": "#ffffff",
    "input.border": "#b9cbd9",
    "input.foreground": "#0f172a",
    "input.placeholderForeground": "#94a3b8",
    "button.background": "#0284c7",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#0369a1",
    "focusBorder": "#0284c7",
    "list.activeSelectionBackground": "#cbe0f0",
    "list.activeSelectionForeground": "#0f172a",
    "list.hoverBackground": "#0284c70d",
    "list.hoverForeground": "#1e293b",
    "list.focusBackground": "#cbe0f0",
    "list.focusForeground": "#1e293b",
    "list.inactiveSelectionBackground": "#dbe9f4",
    "list.inactiveSelectionForeground": "#1e293b",
    "tab.hoverBackground": "#0284c708",
    "tab.hoverBorder": "#b9cbd9",
    "tab.hoverForeground": "#1e293b",
    "tab.unfocusedHoverBackground": "#0284c705",
    "tab.unfocusedHoverBorder": "#b9cbd9",
    "tab.unfocusedHoverForeground": "#64748b",
    "editor.hoverHighlightBackground": "#0284c70d",
    "editorHoverWidget.background": "#ffffff",
    "editorHoverWidget.border": "#b9cbd9",
    "editorHoverWidget.foreground": "#1e293b",
    "editorHoverWidget.statusBarBackground": "#cbdbe7",
    "statusBarItem.hoverBackground": "#0284c70d",
    "statusBarItem.activeBackground": "#0284c71a",
    "activityBar.activeBackground": "#0284c708",
    "menubar.selectionBackground": "#cbe0f0",
    "menubar.selectionForeground": "#1e293b",
    "menu.selectionBackground": "#cbe0f0",
    "menu.selectionForeground": "#1e293b",
    "toolbar.hoverBackground": "#0284c70d",
    "toolbar.hoverOutline": "#00000000",
    "toolbar.activeBackground": "#0284c71a",
    "panel.background": "#f0f7fb",
    "panel.border": "#b9cbd9",
    "panelTitle.activeBorder": "#0284c7",
    "panelTitle.activeForeground": "#0f172a",
    "panelTitle.inactiveForeground": "#64748b",
    "terminal.background": "#f0f7fb",
    "terminal.foreground": "#1e293b"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#64748b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#0369a1"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.type",
        "storage.type.cs"
      ],
      "settings": {
        "foreground": "#0f766e"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#0969da",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#15803d"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#6d28d9"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#1e293b"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#0f172a"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#4f46e5"
      }
    }
  ]
}